# Model auth — optional here: most users connect a provider from the web app's
# AI setup page (or the CLI /login flow). API keys are for dev/advanced use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Markdown/Obsidian knowledge-base vaults (optional)
# Either semicolon-separated name=path pairs:
# EXXETA_KB_VAULTS=notes=~/Documents/Notes;team=~/Documents/TeamKB
# or JSON: {"notes":"~/Documents/Notes"}
EXXETA_KB_VAULTS=

# Web server
PORT=8787

# Web search (SearXNG recommended for local CLI/web research)
# Start a local SearXNG instance with: ./scripts/searxng start
# (Windows, any shell: node scripts\searxng.mjs start)
# Then uncomment:
# EXXETA_SEARCH_PROVIDER=searxng
# EXXETA_SEARCH_BASE_URL=http://127.0.0.1:8888
